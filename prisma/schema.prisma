generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SCAN
  ADMIN
}

enum WorkType {
  MANGA
  MANHWA
  MANHUA
  WEBTOON
  NOVEL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  readingProgresses ReadingProgress[]
  favorites         Favorite[]

  // ✅ Scanlators
  scanlatorMemberships ScanlatorMember[]
  uploadedChapters     Chapter[]         @relation("UserUploadedChapters")
}

model Work {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  coverUrl    String?
  type        WorkType

  chapters          Chapter[]
  readingProgresses ReadingProgress[]
  favorites         Favorite[]

  // ✅ Tags (N:N)
  tags WorkTag[]

  // ✅ Scanlators vinculadas à obra (N:N)
  scanlators WorkScanlator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works WorkTag[]
}

model WorkTag {
  workId    String
  tagId     String
  createdAt DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workId, tagId])
  @@index([tagId])
}

enum ChapterKind {
  IMAGES
  TEXT
}

enum ReadMode {
  SCROLL
  PAGINATED
}

model Chapter {
  id     String @id @default(cuid())
  workId String

  number   Float?
  title    String?
  kind     ChapterKind
  readMode ReadMode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  work  Work          @relation(fields: [workId], references: [id], onDelete: Cascade)
  pages ChapterPage[]
  text  ChapterText?

  readingProgresses ReadingProgress[]

  // ✅ Scanlator “assinando” o capítulo (controle de permissão por scan)
  scanlatorId String?
  scanlator   Scanlator? @relation(fields: [scanlatorId], references: [id], onDelete: SetNull)

  // ✅ Auditoria: qual usuário enviou
  uploadedById String?
  uploadedBy   User?   @relation("UserUploadedChapters", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([workId])
  @@index([scanlatorId])
  @@index([uploadedById])
}

model ChapterPage {
  id        String @id @default(cuid())
  chapterId String
  index     Int
  imageUrl  String

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, index])
  @@index([chapterId])
}

model ChapterText {
  id        String @id @default(cuid())
  chapterId String @unique
  content   String

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

enum ProgressMode {
  SCROLL
  PAGINATED
}

model ReadingProgress {
  id String @id @default(cuid())

  userId    String
  workId    String
  chapterId String

  mode      ProgressMode
  pageIndex Int?
  scrollY   Int?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  work    Work    @relation(fields: [workId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([chapterId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
  @@index([userId])
}

/**
 * ===========================
 * ✅ SCANLATORS (NOVO)
 * ===========================
 */

enum ScanlatorMemberRole {
  OWNER
  EDITOR
}

model Scanlator {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ScanlatorMember[]
  works    WorkScanlator[]
  chapters Chapter[]

  @@index([name])
}

model ScanlatorMember {
  id          String              @id @default(cuid())
  scanlatorId String
  userId      String
  role        ScanlatorMemberRole @default(EDITOR)
  createdAt   DateTime            @default(now())

  scanlator Scanlator @relation(fields: [scanlatorId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scanlatorId, userId])
  @@index([scanlatorId])
  @@index([userId])
}

model WorkScanlator {
  id          String   @id @default(cuid())
  workId      String
  scanlatorId String
  createdAt   DateTime @default(now())

  work      Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  scanlator Scanlator @relation(fields: [scanlatorId], references: [id], onDelete: Cascade)

  @@unique([workId, scanlatorId])
  @@index([workId])
  @@index([scanlatorId])
}
